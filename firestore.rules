rules_version = '2';

// Tennis Court Manager — Firestore Security Rules (Multi-User)
//
// Roles (stored in /users/{uid}.role):
//   'master' → full admin — can read/write everything
//   'user'   → registered user — limited write access
//    null    → anonymous visitor — read only

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    // Safely returns the role stored in /users/{uid}.
    // Uses exists() first so .data never throws a null-pointer error.
    function getRole() {
      let ref = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(ref) ? get(ref).data.role : null;
    }

    // Returns the schoolId linked to the signed-in user's profile.
    function getUserSchoolId() {
      let ref = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(ref) ? get(ref).data.schoolId : null;
    }

    // True when the signed-in user has role == 'master'.
    function isMaster() {
      return request.auth != null && getRole() == 'master';
    }

    // True when the signed-in user has role == 'master' OR 'admin'.
    function isAdminRole() {
      return request.auth != null && (getRole() == 'master' || getRole() == 'admin');
    }

    // True for any signed-in user (regardless of role).
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Venues ───────────────────────────────────────────────────────────────
    match /venues/{docId} {
      allow read: if true;
      allow write: if isAdminRole();
      // School contacts may update their own school's home venue (courts, name, etc.)
      allow update: if isSignedIn() && getUserSchoolId() != null
        && get(/databases/$(database)/documents/schools/$(getUserSchoolId())).data.venueId == docId;
    }

    // ── Schools ──────────────────────────────────────────────────────────────
    match /schools/{docId} {
      allow read: if true;
      allow write: if isAdminRole();
      // School contacts may update their own school record (organisers, contact details)
      allow update: if isSignedIn() && getUserSchoolId() == docId;
    }

    // ── Closures ─────────────────────────────────────────────────────────────
    match /closures/{docId} {
      allow read: if true;
      allow write: if isMaster();
      // School contacts may manage closures for their own venue
      allow create: if isSignedIn() && getUserSchoolId() != null
        && get(/databases/$(database)/documents/schools/$(getUserSchoolId())).data.venueId == request.resource.data.venueId;
      allow delete: if isSignedIn() && getUserSchoolId() != null
        && get(/databases/$(database)/documents/schools/$(getUserSchoolId())).data.venueId == resource.data.venueId;
    }

    // ── Settings ─────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isMaster();
    }

    // ── Bookings ─────────────────────────────────────────────────────────────
    match /bookings/{docId} {
      // Bookings are only visible to signed-in users (not world-readable)
      allow read: if isSignedIn();

      // Admin/master can create any booking; users can only create their own pending requests
      allow create: if isAdminRole()
        || (isSignedIn()
            && request.resource.data.status == 'pending'
            && request.resource.data.requestedBy == request.auth.uid);

      // Admin/master can update any booking; users can update their own pending bookings;
      // venue owners can approve/reject any pending booking at their venue
      allow update: if isAdminRole()
        || (isSignedIn()
            && resource.data.requestedBy == request.auth.uid
            && resource.data.status == 'pending')
        || (isSignedIn()
            && getUserSchoolId() != null
            && get(/databases/$(database)/documents/schools/$(getUserSchoolId())).data.venueId == resource.data.venueId);

      // Admin/master can delete any booking; users can withdraw their own pending ones;
      // venue owners can reject (delete) pending bookings at their venue
      allow delete: if isAdminRole()
        || (isSignedIn()
            && resource.data.requestedBy == request.auth.uid
            && resource.data.status == 'pending')
        || (isSignedIn()
            && getUserSchoolId() != null
            && get(/databases/$(database)/documents/schools/$(getUserSchoolId())).data.venueId == resource.data.venueId);
    }

    // ── Leagues ──────────────────────────────────────────────────────────────
    match /leagues/{docId} {
      allow read:   if true;
      allow create: if isAdminRole();
      allow delete: if isAdminRole();
      // Admin/master can change anything; school contacts may only update
      // the fixtures and standings arrays (score entry, verifications).
      allow update: if isAdminRole()
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['fixtures', 'standings']));
    }

    // ── Tournaments ──────────────────────────────────────────────────────────
    match /tournaments/{docId} {
      allow read:   if true;
      allow create: if isAdminRole();
      allow delete: if isAdminRole();
      allow update: if isAdminRole()
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['fixtures', 'standings', 'results']));
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Any signed-in user can READ the users collection. This is required for:
    //   • _loadProfile: queries collection to determine first-user master role
    //   • loadUsers() in admin panel
    //   • register() checking if any users exist yet
    // Write rules remain strict: users can only create/update their own doc.
    match /users/{uid} {
      allow read:   if isSignedIn();

      allow create: if request.auth != null && request.auth.uid == uid;

      allow update: if isMaster()
        || (request.auth != null
            && request.auth.uid == uid
            && request.resource.data.role == resource.data.role);

      // Admin and master can both remove user profiles from the admin panel
      allow delete: if isAdminRole();
    }

    // ── Audit Log ────────────────────────────────────────────────────────────
    match /auditLog/{docId} {
      allow read:   if isAdminRole();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    // ── League Entries ────────────────────────────────────────────
    // Schools submit team entries; master/admin approve, reject or move them.
    match /leagueEntries/{docId} {
      allow read: if true;

      // Any signed-in user can create an entry (school contact submitting their team)
      allow create: if isSignedIn();

      // The entry creator can withdraw their own pending entry;
      // admin/master can update (approve/reject/move) any entry.
      allow update: if isAdminRole()
        || (isSignedIn()
            && resource.data.enteredBy == request.auth.uid
            && resource.data.status == 'pending');

      allow delete: if isAdminRole()
        || (isSignedIn() && resource.data.enteredBy == request.auth.uid
            && resource.data.status == 'pending');
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // Each document is addressed to one user (uid field).
    // Users can only read/update-as-read their own notifications.
    // Admin (master) can create notifications for any uid.
    // Regular signed-in users can create notifications addressed to themselves
    // (needed for the login-hook reminder checks).
    match /notifications/{docId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow read:   if isAdminRole();

      // Any signed-in user can create a notification for any recipient uid.
      // This is required for school-to-school messaging (reschedule requests,
      // score verification asks, opponent notifications) and self-reminders.
      allow create: if isSignedIn();

      // Only the recipient may mark a notification read
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.read == true
                    && request.resource.data.uid == resource.data.uid;

      allow delete: if isMaster();
    }
  }
}
