rules_version = '2';

// Tennis Court Manager — Firestore Security Rules
//
// Policy:
//   • Anyone (including unauthenticated visitors) can READ all data.
//   • Only an authenticated Firebase user can WRITE (create / update / delete).
//   • This matches the app's master-user model: one admin account, public viewing.
//
// To deploy these rules:
//   firebase deploy --only firestore:rules
// (requires Firebase CLI: npm install -g firebase-tools)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── All collections follow the same public-read / auth-write pattern ──
    match /{collection}/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Settings document (global config) ────────────────────────────────
    match /settings/{settingId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
