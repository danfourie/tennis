rules_version = '2';

// Tennis Court Manager — Firestore Security Rules (Multi-User)
//
// Roles (stored in /users/{uid}.role):
//   'master' → full admin — can read/write everything
//   'user'   → registered user — limited write access
//    null    → anonymous visitor — read only

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    // Safely returns the role stored in /users/{uid}.
    // Uses exists() first so .data never throws a null-pointer error.
    function getRole() {
      let ref = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(ref) ? get(ref).data.role : null;
    }

    // True when the signed-in user has role == 'master'.
    function isMaster() {
      return request.auth != null && getRole() == 'master';
    }

    // True for any signed-in user (regardless of role).
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Venues ───────────────────────────────────────────────────────────────
    match /venues/{docId} {
      allow read:  if true;
      allow write: if isMaster();
    }

    // ── Schools ──────────────────────────────────────────────────────────────
    match /schools/{docId} {
      allow read:  if true;
      allow write: if isMaster();
    }

    // ── Closures ─────────────────────────────────────────────────────────────
    match /closures/{docId} {
      allow read:  if true;
      allow write: if isMaster();
    }

    // ── Settings ─────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isMaster();
    }

    // ── Bookings ─────────────────────────────────────────────────────────────
    match /bookings/{docId} {
      allow read: if true;

      allow create: if isMaster()
        || (isSignedIn()
            && request.resource.data.status == 'pending'
            && request.resource.data.requestedBy == request.auth.uid);

      allow update: if isMaster()
        || (isSignedIn()
            && resource.data.requestedBy == request.auth.uid
            && resource.data.status == 'pending');

      allow delete: if isMaster()
        || (isSignedIn()
            && resource.data.requestedBy == request.auth.uid
            && resource.data.status == 'pending');
    }

    // ── Leagues ──────────────────────────────────────────────────────────────
    match /leagues/{docId} {
      allow read:   if true;
      allow create: if isMaster();
      allow delete: if isMaster();
      allow update: if isSignedIn();
    }

    // ── Tournaments ──────────────────────────────────────────────────────────
    match /tournaments/{docId} {
      allow read:   if true;
      allow create: if isMaster();
      allow delete: if isMaster();
      allow update: if isSignedIn();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // IMPORTANT: self-read is checked WITHOUT calling isMaster() to avoid
    // a circular get() that would deny the read before the role is known.
    match /users/{uid} {
      // Any authenticated user can always read their own profile
      allow read: if request.auth != null && request.auth.uid == uid;
      // Master can read all profiles
      allow read: if isMaster();

      allow create: if request.auth != null && request.auth.uid == uid;

      allow update: if isMaster()
        || (request.auth != null
            && request.auth.uid == uid
            && request.resource.data.role == resource.data.role);

      allow delete: if isMaster();
    }

    // ── Audit Log ────────────────────────────────────────────────────────────
    match /auditLog/{docId} {
      allow read:   if isMaster();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }
  }
}
